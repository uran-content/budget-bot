# Токен Telegram бота (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# ID администраторов (через запятую)
ADMIN_IDS=123456789,987654321

# TRC20 адрес для мониторинга
TRC20_ADDRESS=TYourTrc20AddressHere

# API ключ TronGrid (необязательно, но рекомендуется для стабильной работы)
# Получить на https://www.trongrid.io/
TRONGRID_API_KEY=

# Интервал опроса TronGrid в секундах (по умолчанию 15)
POLL_INTERVAL=15
